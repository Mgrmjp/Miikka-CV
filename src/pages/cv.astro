---
import BaseLayout from "../layouts/BaseLayout.astro";
import CvDocument from "../components/CvDocument.astro";
import SiteHeader from "../components/SiteHeader.astro";
import { cvPage, navCv, profile } from "../data/profile";
---

<BaseLayout title={`${profile.name} | Ansioluettelo`} description={cvPage.intro}>
  <SiteHeader navItems={navCv} ctaHref={`mailto:${profile.email}`} ctaLabel="Sähköposti" />

  <div class="container container--narrow">
    <CvDocument />
  </div>
</BaseLayout>
