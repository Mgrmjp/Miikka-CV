---
import BaseLayout from "../layouts/BaseLayout.astro";
import SiteHeader from "../components/SiteHeader.astro";
import FooterViz from "../components/FooterViz.astro";
import { navPortfolio, profile } from "../data/profile";
---

<BaseLayout title={`404 – Sivua ei löydy – ${profile.name}`} description="Etsimääsi sivua ei löytynyt.">
  <SiteHeader navItems={navPortfolio} ctaVariant="secondary" />

  <main id="main">
    <div class="not-found container">
      <div class="not-found__card">
        <h1 class="not-found__code">404</h1>
        <p class="not-found__message">Sivua ei löydy</p>
        <p class="not-found__hint">
          Etsimääsi osoitetta ei ole olemassa. Jos tämä on virhe,
          <a href={`mailto:${profile.email}`}>kerro siitä minulle</a>.
        </p>
        <a href="/" class="btn btn--primary">&larr; Etusivulle</a>
      </div>
    </div>
  </main>

  <FooterViz />
</BaseLayout>

<style>
  .not-found {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: 60vh;
    padding: var(--space-3xl) 0;
  }

  .not-found__card {
    text-align: center;
    max-width: 24rem;
  }

  .not-found__code {
    font-size: 5rem;
    font-weight: 800;
    line-height: 1;
    margin: 0 0 var(--space-xs);
    color: var(--accent);
    letter-spacing: -0.05em;
  }

  .not-found__message {
    font-size: 1.125rem;
    font-weight: 600;
    margin: 0 0 var(--space-md);
    color: var(--color-ink);
  }

  .not-found__hint {
    font-size: 0.9375rem;
    line-height: 1.6;
    color: var(--color-muted);
    margin: 0 0 var(--space-xl);
  }

  .not-found__hint a {
    color: var(--accent);
    text-decoration: underline;
    text-underline-offset: 2px;
  }
</style>
