---
import BaseLayout from "../layouts/BaseLayout.astro";
import FooterViz from "../components/FooterViz.astro";
import CompanyLink from "../components/CompanyLink.astro";
import Hero from "../components/Hero.astro";
import ProofStrip from "../components/ProofStrip.astro";
import TechnicalCoreSection from "../components/TechnicalCoreSection.astro";
import NewWindowHint from "../components/NewWindowHint.astro";
import Section from "../components/Section.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import StoryArticle from "../components/StoryArticle.astro";
import ContactForm from "../components/ContactForm.astro";
import {
  about,
  interests,
  contactCta,
  cvSections,
  experiences,
  navPortfolio,
  personalProjects,
  personalProjectsSection,
  portfolio,
  profile,
  stories
} from "../data/profile";
---

<BaseLayout
  title={profile.portfolioMetaTitle}
  description={profile.portfolioMetaDescription}
>
  <SiteHeader navItems={navPortfolio} ctaVariant="secondary" />

  <main id="main" class="page-portfolio">
    <div class="container">
      <Hero />
    </div>

    <div class="proof-strips">
      <ProofStrip />
    </div>

    <div class="case-band">
      <div class="container">
        <Section
          id="tyonaytteet"
          label={portfolio.proofSection.label}
          title={portfolio.proofSection.title}
          intro={portfolio.proofSection.intro}
          variant="cases"
        >
          <div class="story-grid">
            {
              stories.map((story, i) => (
                <StoryArticle
                  index={`0${i + 1}`}
                  title={story.title}
                  mess={story.mess}
                  work={story.work}
                  outcome={story.outcome}
                  tags={story.tags}
                />
              ))
            }
          </div>
        </Section>
      </div>
    </div>

    <div class="proof-strips">
      <TechnicalCoreSection />
    </div>

    <div class="container">
      <Section
        id="kokemus"
        label={portfolio.experienceSection.label}
        title={portfolio.experienceSection.title}
        intro={portfolio.experienceSection.intro}
      >
        <div class="experience-list">
          {
            experiences.map((job) => (
              <article class="experience-card card">
                <CompanyLink name={job.company} url={job.url} />
                <p class="experience-card__role">{job.role}</p>
                <p class="experience-card__period">
                  {job.period} · {job.location}
                </p>
                <ul>
                  {job.bullets.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </Section>

      <Section
        id="omat"
        label={personalProjectsSection.label}
        title={personalProjectsSection.title}
        intro={personalProjectsSection.intro}
      >
        <div class="project-list">
          {
            personalProjects.map((project) => (
              <ProjectCard
                name={project.name}
                url={project.url}
                hostname={project.hostname}
                description={project.description}
                tags={project.tags}
              />
            ))
          }
        </div>
      </Section>

      <Section id="mina" label="Tausta" title={about.title} intro={profile.positioning}>
        <p class="about-short">{about.short}</p>
        {
          about.paragraphs.map((p) => (
            <p class="about-short">{p}</p>
          ))
        }
        <p class="about-short">{about.interestsBlurb}</p>
        <ul class="interest-row" aria-label="Kiinnostuksen kohteet">
          {interests.map((item) => <li>{item}</li>)}
        </ul>
        <p class="about-short about-short--link">
          <a href="/cv">Ansioluettelo</a>: kokemus, asiakastyö, koulutus ja kielet.
        </p>
      </Section>

      <Section
        id="yhteys"
        label="Yhteys"
        title="Kerro, mikä sotku sulla on"
        intro={contactCta.offer}
        variant="contact"
      >
        <div class="actions contact-actions">
          {
            contactCta.links.map((link) => (
              <a
                class:list={[
                  "btn",
                  link.primary && "btn--primary",
                  !link.primary && !link.download && "btn--secondary",
                  link.download && "btn--secondary",
                  link.external && "link-external"
                ]}
                href={link.href}
                {...link.external ? { target: "_blank", rel: "noopener noreferrer" } : {}}
                {...link.download ? { download: true } : {}}
              >
                {link.label}
                {link.external ? <NewWindowHint /> : null}
              </a>
            ))
          }
        </div>
        <ContactForm />
        <p class="contact-note">Vastaan yleensä arkipäivisin. Ei myyntipuhetta ennen kuin näen, mitä on rikki.</p>
      </Section>
    </div>
  </main>

  <FooterViz />
</BaseLayout>
