---
import BaseLayout from "../layouts/BaseLayout.astro";
import FooterViz from "../components/FooterViz.astro";
import Hero from "../components/Hero.astro";
import HelpCards from "../components/HelpCards.astro";
import TechnicalCoreSection from "../components/TechnicalCoreSection.astro";
import NewWindowHint from "../components/NewWindowHint.astro";
import Section from "../components/Section.astro";
import SiteHeader from "../components/SiteHeader.astro";
import StoryArticle from "../components/StoryArticle.astro";
import ProjectCard from "../components/ProjectCard.astro";
import ContactForm from "../components/ContactForm.astro";
import {
  about,
  contactCta,
  experiences,
  helpSection,
  interests,
  navPortfolio,
  personalProjects,
  personalProjectsSection,
  portfolio,
  profile,
  stories
} from "../data/profile";
---

<BaseLayout
  title={profile.portfolioMetaTitle}
  description={profile.portfolioMetaDescription}
>
  <SiteHeader navItems={navPortfolio} ctaVariant="secondary" />

  <main id="main" class="page-portfolio">
    <div class="container">
      <Hero />
    </div>

    <div class="container">
      <section class="help-section" id="apua" aria-labelledby="apua-title">
        <header class="help-section__head">
          <p class="eyebrow">{helpSection.label}</p>
          <h2 id="apua-title">{helpSection.title}</h2>
          <p class="help-section__intro">{helpSection.intro}</p>
        </header>
        <HelpCards />
      </section>
    </div>

    <div class="case-band">
      <div class="container">
        <Section
          id="tyonaytteet"
          label={portfolio.proofSection.label}
          title={portfolio.proofSection.title}
          intro={portfolio.proofSection.intro}
          variant="cases"
        >
          <div class="story-grid">
            {
              stories.map((story, i) => (
                <StoryArticle
                  index={`0${i + 1}`}
                  title={story.title}
                  mess={story.mess}
                  work={story.work}
                  outcome={story.outcome}
                  tags={story.tags}
                />
              ))
            }
          </div>
        </Section>
      </div>
    </div>

    <div class="proof-strips">
      <TechnicalCoreSection />
    </div>

    <div class="container">
      <Section
        id="kokemus"
        label={portfolio.experienceSection.label}
        title={portfolio.experienceSection.title}
        intro={portfolio.experienceSection.intro}
      >
        <div class="timeline">
          {
            experiences.map((job) => (
              <article class="timeline__item">
                <span class="timeline__dot" aria-hidden="true" />
                <div class="timeline__body">
                  <h3 class="timeline__role">{job.role}</h3>
                  <p class="timeline__meta">
                    <a class="timeline__company" href={job.url} rel="noopener noreferrer" target="_blank">
                      {job.company}
                    </a>
                    <span class="timeline__sep">·</span>
                    <span>{job.period}</span>
                    <span class="timeline__sep">·</span>
                    <span>{job.location}</span>
                  </p>
                  <ul class="timeline__bullets">
                    {job.bullets.map((item) => <li>{item}</li>)}
                  </ul>
                </div>
              </article>
            ))
          }
        </div>
      </Section>

      <Section
        id="omat"
        label={personalProjectsSection.label}
        title={personalProjectsSection.title}
        intro={personalProjectsSection.intro}
      >
        <div class="project-grid">
          {
            personalProjects.map((project) => (
              <ProjectCard
                name={project.name}
                url={project.url}
                hostname={project.hostname}
                description={project.description}
                tags={project.tags}
              />
            ))
          }
        </div>
      </Section>

      <Section id="mina" label="Tausta" title={about.title}>
        <div class="about-body">
          {about.paragraphs.map((p) => <p class="about-short">{p}</p>)}
          <ul class="interest-row" aria-label="Kiinnostuksen kohteet">
            {interests.map((item) => <li>{item}</li>)}
          </ul>
          <p class="about-short about-short--link">
            <a href="/cv">Ansioluettelo</a>: kokemus, asiakastyö, koulutus ja kielet.
          </p>
        </div>
      </Section>
    </div>

    <div class="contact-band" id="yhteys">
      <div class="container">
        <header class="contact-band__head">
          <p class="eyebrow">Yhteys</p>
          <h2>{contactCta.title}</h2>
          <p class="contact-band__sub">{contactCta.support}</p>
        </header>
        <div class="contact-band__grid">
          <div class="contact-band__main">
            <ContactForm turnstileSiteKey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "0x4AAAAAAA0xEXAMPLE"} />
          </div>
          <aside class="contact-band__aside">
            <p class="contact-band__aside-title">Suorat kanavat</p>
            <ul class="contact-band__links">
              {
                contactCta.links.map((link) => (
                  <li>
                    <a
                      class="contact-band__link link-external"
                      href={link.href}
                      {...link.external ? { target: "_blank", rel: "noopener noreferrer" } : {}}
                      {...link.download ? { download: true } : {}}
                    >
                      {link.label}
                      {link.external ? <NewWindowHint /> : null}
                    </a>
                  </li>
                ))
              }
            </ul>
            <p class="contact-band__note">Vastaan yleensä arkipäivisin. Ei myyntipuhetta ennen kuin näen, mikä on rikki.</p>
          </aside>
        </div>
      </div>
    </div>
  </main>

  <FooterViz />
</BaseLayout>
