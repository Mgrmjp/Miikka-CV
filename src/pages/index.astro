---
import BaseLayout from "../layouts/BaseLayout.astro";
import FooterViz from "../components/FooterViz.astro";
import CompanyLink from "../components/CompanyLink.astro";
import Hero from "../components/Hero.astro";
import ProofStrip from "../components/ProofStrip.astro";
import TechnicalCoreSection from "../components/TechnicalCoreSection.astro";
import NewWindowHint from "../components/NewWindowHint.astro";
import Section from "../components/Section.astro";
import SiteHeader from "../components/SiteHeader.astro";
import ProjectCard from "../components/ProjectCard.astro";
import StoryArticle from "../components/StoryArticle.astro";
import ContactForm from "../components/ContactForm.astro";
import {
  about,
  interests,
  contactCta,
  cvSections,
  experiences,
  navPortfolio,
  personalProjects,
  personalProjectsSection,
  portfolio,
  profile,
  stories
} from "../data/profile";
---

<BaseLayout
  title={profile.portfolioMetaTitle}
  description={profile.portfolioMetaDescription}
>
  <SiteHeader navItems={navPortfolio} ctaVariant="secondary" />

  <main id="main" class="page-portfolio">
    <div class="container">
      <Hero />
    </div>

    <div class="proof-strips">
      <ProofStrip />
    </div>

    <div class="case-band">
      <div class="container">
        <Section
          id="tyonaytteet"
          label={portfolio.proofSection.label}
          title={portfolio.proofSection.title}
          intro={portfolio.proofSection.intro}
          variant="cases"
        >
          <div class="story-grid">
            {
              stories.map((story, i) => (
                <StoryArticle
                  index={`0${i + 1}`}
                  title={story.title}
                  mess={story.mess}
                  work={story.work}
                  outcome={story.outcome}
                  tags={story.tags}
                />
              ))
            }
          </div>
        </Section>
      </div>
    </div>

    <div class="proof-strips">
      <TechnicalCoreSection />
    </div>

    <div class="container">
      <Section
        id="kokemus"
        label={portfolio.experienceSection.label}
        title={portfolio.experienceSection.title}
        intro={portfolio.experienceSection.intro}
      >
        <div class="experience-list">
          {
            experiences.map((job) => (
              <article class="experience-card card">
                <CompanyLink name={job.company} url={job.url} />
                <p class="experience-card__role">{job.role}</p>
                <p class="experience-card__period">
                  {job.period} · {job.location}
                </p>
                <ul>
                  {job.bullets.map((item) => <li>{item}</li>)}
                </ul>
              </article>
            ))
          }
        </div>
      </Section>

      <Section
        id="omat"
        label={personalProjectsSection.label}
        title={personalProjectsSection.title}
        intro={personalProjectsSection.intro}
      >
        <div class="project-list">
          {
            personalProjects.map((project) => (
              <ProjectCard
                name={project.name}
                url={project.url}
                hostname={project.hostname}
                description={project.description}
                tags={project.tags}
              />
            ))
          }
        </div>
      </Section>

      <Section id="mina" label="Tausta" title={about.title} intro={profile.positioning}>
        <p class="about-short">{about.short}</p>
        {
          about.paragraphs.map((p) => (
            <p class="about-short">{p}</p>
          ))
        }
        <p class="about-short">{about.interestsBlurb}</p>
        <ul class="interest-row" aria-label="Kiinnostuksen kohteet">
          {interests.map((item) => <li>{item}</li>)}
        </ul>
        <p class="about-short about-short--link">
          <a href="/cv">Ansioluettelo</a>: kokemus, asiakastyö, koulutus ja kielet.
        </p>
      </Section>

      <Section
        id="yhteys"
        label="Yhteys"
        title="Kerro, mikä sotku sulla on"
        intro={contactCta.offer}
        variant="contact"
      >
        <div class="contact-panel">
          <div class="contact-panel__main">
            <p class="contact-panel__form-title">Lähetä viesti</p>
            <ContactForm turnstileSiteKey={import.meta.env.PUBLIC_TURNSTILE_SITE_KEY || "0x4AAAAAAA0xEXAMPLE"} />
          </div>
          <aside class="contact-panel__info">
            <div class="contact-panel__actions">
              {
                contactCta.links.map((link) => (
                  <a
                    class:list={[
                      "contact-panel__action",
                      link.key === "A" && "contact-panel__action--active"
                    ]}
                    href={link.href}
                    {...link.external ? { target: "_blank", rel: "noopener noreferrer" } : {}}
                    {...link.download ? { download: true } : {}}
                  >
                    {link.label}
                    {link.external ? <NewWindowHint /> : null}
                  </a>
                ))
              }
            </div>

            <div class="contact-panel__situations">
              <p class="contact-panel__situations-title">
                Millaisissa tilanteissa voin auttaa?
              </p>
              <ul class="contact-panel__checklist">
                <li>WordPress tai WooCommerce hajoaa</li>
                <li>Integraatio ei liiku</li>
                <li>Maksut, liidit tai raportointi eivät täsmää</li>
                <li>Suorituskyky tökkii</li>
                <li>Kukaan ei enää tiedä, mikä on rikki</li>
              </ul>
            </div>

            <div class="contact-panel__note">
              <p>Vastaan yleensä arkipäivisin. Ei myyntipuhetta ennen kuin näen, mikä on rikki.</p>
            </div>
          </aside>
        </div>
        <div class="contact-panel__footer">
          <span>Vastaan yleensä arkipäivisin.</span>
          <a href="/tietosuoja" class="contact-panel__footer-link">Tietosuojaseloste</a>
        </div>
      </Section>
    </div>
  </main>

  <FooterViz />
</BaseLayout>
