---
type Props = {
  src: string;
  placeholderSrc: string;
  alt: string;
  width?: number;
  height?: number;
  loading?: "lazy" | "eager";
  class?: string;
};

const {
  src,
  placeholderSrc,
  alt,
  width,
  height,
  loading = "lazy",
  class: className
} = Astro.props;

const markLoaded =
  "this.closest('[data-progressive-image]')?.classList.add('is-loaded')";
---

<span class:list={["progressive-image", className]} data-progressive-image>
  <img
    class="progressive-image__placeholder"
    src={placeholderSrc}
    alt=""
    aria-hidden="true"
    width={width}
    height={height}
    decoding="async"
  />
  <img
    class="progressive-image__full"
    src={src}
    alt={alt}
    width={width}
    height={height}
    loading={loading}
    decoding="async"
    onload={markLoaded}
    onerror={markLoaded}
  />
</span>
