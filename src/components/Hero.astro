---
import { credibilityBlocks, cvSections, hero, profile } from "../data/profile";
import QuickFacts from "./QuickFacts.astro";
import ProfilePhoto from "./ProfilePhoto.astro";
---

<header class="hero">
  <div class="hero__layout">
    <div class="hero__content">
      <p class="eyebrow">{hero.eyebrow}</p>
      <h1>{profile.name}</h1>
      <p class="hero__headline">{hero.headline}</p>
      <p class="hero__lead">{hero.support}</p>
      <div class="actions hero__actions">
        <a class="btn btn--primary" href="#tyonaytteet">Katso työnäytteet</a>
        <a class="btn btn--secondary" href={profile.cvPath} download>
          {cvSections.downloadPdfShort}
        </a>
      </div>
    </div>

    <div class="hero__aside">
      <div class="hero__aside-stack">
        <div class="hero__photo-frame">
          <ProfilePhoto size="lg" class="hero__photo" />
        </div>
        <QuickFacts />
      </div>
    </div>
  </div>

  <ul class="credibility-row" aria-label="Luottamuksen perusteet">
    {
      credibilityBlocks.map((item) => (
        <li class="credibility-row__item">
          <p>{item}</p>
        </li>
      ))
    }
  </ul>
</header>
