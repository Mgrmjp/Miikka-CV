---
import CvPreviewButton from "./CvPreviewButton.astro";
import { cvSections, cvSnapshot, profile } from "../data/profile";
---

<aside class="cv-snapshot card" aria-label="CV-yhteenveto">
  <p class="eyebrow">CV-yhteenveto</p>
  <p class="cv-snapshot__title">{cvSnapshot.title}</p>
  <ul class="cv-snapshot__facts">
    <li>{cvSnapshot.tenure}</li>
    <li>{cvSnapshot.location}</li>
    <li>{cvSnapshot.focus}</li>
    <li>{cvSnapshot.openTo}</li>
  </ul>
  <div class="actions cv-snapshot__actions">
    <a class="btn btn--primary btn--sm" href={profile.cvPath} download>
      {cvSections.downloadPdf}
    </a>
    <CvPreviewButton size="sm" />
    <a class="btn btn--secondary btn--sm" href="/cv">Täydellinen CV</a>
  </div>
</aside>
