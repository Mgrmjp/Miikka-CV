---
import ExternalLinkIcon from "./ExternalLinkIcon.astro";
import NewWindowHint from "./NewWindowHint.astro";
import { cvSections } from "../data/profile";

type Props = {
  name: string;
  url: string;
  hostname: string;
  description: string;
  tags: readonly string[];
};

const { name, url, hostname, description, tags } = Astro.props;
const tagLine = tags.join(" · ");
---

<article class="project-row">
  <div class="project-row__main">
    <h3 class="project-row__title">
      <a class="link-external" href={url} rel="noopener noreferrer" target="_blank">
        {name}
        <NewWindowHint />
        <ExternalLinkIcon />
      </a>
    </h3>
    <p class="project-row__host">{hostname}</p>
    <p class="project-row__desc">{description}</p>
  </div>
  <div class="project-row__aside">
    <p class="project-row__meta">{tagLine}</p>
    <a class="project-row__cta link-external" href={url} rel="noopener noreferrer" target="_blank">
      {cvSections.openSite}
      <NewWindowHint />
      <ExternalLinkIcon />
    </a>
  </div>
</article>
