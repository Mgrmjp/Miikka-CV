---
import ProgressiveImage from "./ProgressiveImage.astro";
import { profile } from "../data/profile";

type Props = {
  size?: "sm" | "md" | "lg";
  class?: string;
  alt?: string;
};

const { size = "md", class: className, alt = profile.avatarAlt } = Astro.props;
---

<ProgressiveImage
  class:list={["profile-photo", `profile-photo--${size}`, className]}
  src={profile.avatar}
  placeholderSrc={profile.avatarPlaceholder}
  webpSrc={profile.avatarWebp}
  alt={alt}
  width={1086}
  height={1086}
  loading={size === "lg" ? "eager" : "lazy"}
  data-sway
/>

<script>
  (() => {
    const mq = window.matchMedia("(prefers-reduced-motion: reduce)");
    if (mq.matches) return;

    const els = document.querySelectorAll<HTMLElement>(
      ".profile-photo[data-sway]"
    );
    if (!els.length) return;

    let start: number | null = null;
    const AMPLITUDE = 2.5;  // degrees
    const PERIOD = 4200;    // ms

    function sway(timestamp: number) {
      if (start === null) start = timestamp;
      const elapsed = timestamp - start;
      const a = Math.sin((elapsed / PERIOD) * Math.PI * 2) * AMPLITUDE;
      els.forEach((el) => {
        el.style.transform = `rotate(${a}deg)`;
      });
      requestAnimationFrame(sway);
    }

    requestAnimationFrame(sway);
  })();
</script>
